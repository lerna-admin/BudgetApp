# Storage
BUDGETAPP_STORAGE_ROOT=/home/xanadu/disco_portatil/proyectos/budgetapp
BUDGETAPP_MEMORY_LOG_PATH=/home/xanadu/disco_portatil/proyectos/budgetapp/logs/logs.jsonl

# ClickUp
CLICKUP_API_TOKEN=replace_me
CLICKUP_TEAM_ID=replace_me
CLICKUP_SPACE_ID=replace_me
CLICKUP_LIST_ID=replace_me
CLICKUP_API_BASE_URL=https://api.clickup.com/api/v2
# Optional: array query encoding mode for statuses/tags
CLICKUP_ARRAY_MODE=bracket

# Telegram DM control
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
# Optional bootstrap: auto-autoriza primeros N usuarios por DM y guarda allowlist en disco
TELEGRAM_BOOTSTRAP_MAX_USERS=0
# Codex local mode for Telegram
TELEGRAM_CODEX_ENABLED=1
TELEGRAM_CODEX_BIN=codex
TELEGRAM_CODEX_WORKDIR=/home/xanadu/projects/budgetapp/app
TELEGRAM_CODEX_TIMEOUT_MS=120000
TELEGRAM_CODEX_MAX_ACTIONS=4
# Optional map Telegram user -> ClickUp user id
TELEGRAM_TO_CLICKUP_USER_MAP={"7829032497":66879759}
# Optional local audio transcription (voice/audio -> text)
TELEGRAM_AUDIO_ENABLED=1
TELEGRAM_AUDIO_MAX_SECONDS=240
TELEGRAM_STT_LANGUAGE=es
TELEGRAM_STT_THREADS=4
TELEGRAM_STT_WHISPER_BIN=/home/xanadu/disco_portatil/proyectos/budgetapp/tools/whisper.cpp/build/bin/whisper-cli
TELEGRAM_STT_WHISPER_MODEL=/home/xanadu/disco_portatil/proyectos/budgetapp/tools/whisper.cpp/models/ggml-tiny.bin
